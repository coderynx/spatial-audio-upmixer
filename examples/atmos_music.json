{
  "_comment": "7.1.4 ADM-BWF music-authoring bed for downstream authoring, QC, and encoding",

  "version": "1.0",

  "metadata": {
    "name": "7.1.4 ADM-BWF Music Bed",
    "description": "Spatial Audio Upmixer bed for downstream immersive authoring"
  },

  "engine": {
    "mode": "stem",
    "stems": ["vocals", "bass", "drums", "guitar", "piano", "other"],
    "stem_silence_skip": true
  },

  "mixing": {
    "channel_layout": "7.1.4",
    "stem_source_anchor_strength": 0.5,
    "spatial": {
      "profile": "spacious",
      "intensity": 0.8
    }
  },

  "format": {
    "type": "adm-bwf",
    "subtype": "PCM_24",
    "sample_rate": 48000
  },

  "mastering": {
    "eq": {
      "profile": "atmos-streaming",
      "strength": 0.8
    },
    "compressor": {
      "profile": "glue"
    },
    "loudness": {
      "normalize": true,
      "target": -18.0,
      "max_tp": -1.0
    }
  },

  "assets": [
    {
      "input":  "stereo.flac",
      "output": "atmos_music.wav"
    }
  ]
}
