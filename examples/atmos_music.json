{
  "_comment": "Dolby Atmos Music Master Delivery — JSON manifest example",

  "version": "1.0",

  "metadata": {
    "name": "Atmos Music Master",
    "description": "Dolby Atmos Music Master Delivery — streaming platforms"
  },

  "engine": {
    "mode": "stem"
  },

  "mixing": {
    "channel_layout": "7.1.4"
  },

  "format": {
    "type": "adm-bwf",
    "subtype": "PCM_24",
    "sample_rate": 48000
  },

  "mastering": {
    "eq": {
      "profile": "atmos-streaming",
      "strength": 1.0
    },
    "compressor": {
      "profile": "glue"
    },
    "loudness": {
      "normalize": true,
      "target": -18.0,
      "max_tp": -1.0
    }
  },

  "assets": [
    {
      "input":  "stereo.flac",
      "output": "atmos_music.wav"
    }
  ]
}
